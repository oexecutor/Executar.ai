PUBLIC_BASE_URL=https://your-project.vercel.app
MCP_JWT_SECRET=replace-with-at-least-32-random-bytes

# Public Supabase configuration. The publishable key is intentionally safe
# for the browser; authorization is enforced by Auth + RLS.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=

# Server-only key used by the MCP after the user explicitly authorizes a
# workspace. Never prefix this variable with VITE_ or expose it to the web.
SUPABASE_SERVICE_ROLE_KEY=

# Existing OAuth client registry remains in Postgres during the incremental
# migration. This may point to the Supabase transaction pooler.
DATABASE_URL=

# Deprecated operator login is intentionally not used by Phase 4.
ADMIN_PASSWORD=

# Smoke tests.
SMOKE_BASE_URL=http://localhost:3000
