PUBLIC_BASE_URL=https://your-site.netlify.app
MCP_JWT_SECRET=replace-with-at-least-32-random-bytes

# Gate 0.5 — operator password for the admin session. Login fails closed
# while this is unset. Generate a strong value, e.g.: openssl rand -base64 24
ADMIN_PASSWORD=

# Only used by `npm run test:smoke` (scripts/smoke-oauth.mjs), never by the
# app itself. SMOKE_BASE_URL is required; SMOKE_ADMIN_PASSWORD is optional —
# without it, the script skips the /api/vault/* checks and only exercises
# OAuth/MCP (which has never been session-gated). Set it to the same value
# as ADMIN_PASSWORD in the environment you're smoke-testing.
SMOKE_BASE_URL=http://localhost:8888
SMOKE_ADMIN_PASSWORD=
