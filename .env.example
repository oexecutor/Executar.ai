# Base URL of the deployed site (no trailing slash)
PUBLIC_BASE_URL=https://example.netlify.app

# Secret used to sign admin-session and MCP JWTs. Generate with:
#   openssl rand -hex 32
MCP_JWT_SECRET=

# Operator password for the admin session (Gate 0.5, baseline §13 Option B).
# Login fails closed while this is unset.
ADMIN_PASSWORD=
