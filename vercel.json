{
  "buildCommand": "npm run install:web && npm run build:web && npm run build",
  "outputDirectory": "public",
  "rewrites": [
    { "source": "/health", "destination": "/api/health" },
    { "source": "/mcp", "destination": "/api/mcp" },
    { "source": "/oauth/register", "destination": "/api/oauth" },
    { "source": "/oauth/token", "destination": "/api/oauth" },
    { "source": "/oauth/authorize", "destination": "/api/oauth" },
    { "source": "/.well-known/oauth-protected-resource", "destination": "/api/oauth" },
    { "source": "/.well-known/oauth-protected-resource/mcp", "destination": "/api/oauth" },
    { "source": "/.well-known/oauth-authorization-server", "destination": "/api/oauth" },
    { "source": "/view", "destination": "/api/vault" },
    { "source": "/dashboard", "destination": "/api/workflow-dashboard" },
    { "source": "/api/admin/login", "destination": "/api/admin" },
    { "source": "/api/admin/logout", "destination": "/api/admin" },
    { "source": "/api/auth/config", "destination": "/api/admin" },
    { "source": "/api/auth/workspaces", "destination": "/api/admin" },
    { "source": "/api/auth/session", "destination": "/api/admin" },
    { "source": "/api/auth/me", "destination": "/api/admin" },
    { "source": "/api/auth/logout", "destination": "/api/admin" },
    { "source": "/api/vault/status", "destination": "/api/vault" },
    { "source": "/api/vault/export", "destination": "/api/vault" },
    { "source": "/api/vault/files", "destination": "/api/vault" },
    { "source": "/api/vault/import", "destination": "/api/vault" },
    { "source": "/api/pm/:path*", "destination": "/api/pm" },
    { "source": "/api/executar/:path*", "destination": "/api/executar" },
    { "source": "/api/blog/newsletter", "destination": "/api/blog" },
    { "source": "/entrar", "destination": "/index.html" },
    { "source": "/app", "destination": "/app/index.html" },
    { "source": "/app/:path*", "destination": "/app/index.html" },
    { "source": "/blog", "destination": "/blog/index.html" },
    { "source": "/blog/:path*", "destination": "/blog/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "no-referrer" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; connect-src 'self' https://*.supabase.co wss://*.supabase.co; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; worker-src 'self'; manifest-src 'self'; object-src 'none'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'" }
      ]
    }
  ]
}
