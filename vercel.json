{
  "buildCommand": "npm run install:web && npm run build:web && npm run build",
  "outputDirectory": "public",
  "rewrites": [
    { "source": "/health", "destination": "/api/health" },
    { "source": "/mcp", "destination": "/api/mcp" },
    { "source": "/oauth/register", "destination": "/api/oauth-register" },
    { "source": "/oauth/token", "destination": "/api/oauth-token" },
    { "source": "/oauth/authorize", "destination": "/api/oauth-authorize" },
    { "source": "/.well-known/oauth-protected-resource", "destination": "/api/oauth-metadata" },
    { "source": "/.well-known/oauth-protected-resource/mcp", "destination": "/api/oauth-metadata" },
    { "source": "/.well-known/oauth-authorization-server", "destination": "/api/oauth-metadata" },
    { "source": "/view", "destination": "/api/vault-view" },
    { "source": "/dashboard", "destination": "/api/workflow-dashboard" },
    { "source": "/api/admin/login", "destination": "/api/admin-login" },
    { "source": "/api/admin/logout", "destination": "/api/admin-logout" },
    { "source": "/api/vault/status", "destination": "/api/vault-status" },
    { "source": "/api/vault/export", "destination": "/api/vault-export" },
    { "source": "/api/vault/files", "destination": "/api/vault-files" },
    { "source": "/api/vault/import", "destination": "/api/vault-import" },
    { "source": "/api/pm/:path*", "destination": "/api/pm" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "no-referrer" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; style-src 'unsafe-inline'; script-src 'unsafe-inline'; object-src 'none'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'" }
      ]
    }
  ]
}
